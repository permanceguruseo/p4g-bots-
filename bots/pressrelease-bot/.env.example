# ── Copy to .env and fill in. Each bot has its own .env ──

# Dashboard this bot coordinates with
API_BASE_URL=https://p4g-seo-platform.onrender.com
# API key (set once the dashboard has auth turned on; leave blank until then)
API_KEY=

# Which task type this bot claims (directory | article | rss | microblog | web2 | guestpost | pptpdf | image | classified | pressrelease | profile)
BOT_TYPE=pressrelease

# Poll + browser
POLL_INTERVAL=15000
HEADLESS=true

# Content generation (article/microblog/web2/guestpost/pressrelease bots)
ANTHROPIC_API_KEY=

# CAPTCHA solving (only bots hitting CAPTCHA sites)
TWOCAPTCHA_API_KEY=

# Email OTP (only bots hitting OTP sites)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Safety pacing
DAILY_CAP_PER_SITE=3
MIN_DELAY=2000
MAX_DELAY=6000
